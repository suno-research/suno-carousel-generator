# URL do backend (em produção: https://suno-carousel-backend.onrender.com)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# NextAuth — gera um valor com `openssl rand -base64 32`
NEXTAUTH_SECRET=
# URL do próprio frontend (em produção: https://suno-carrossel.vercel.app)
NEXTAUTH_URL=http://localhost:3001

# Google OAuth (criar em https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
